# Copy to .env.local for local dev. CI sets these as repo Variables.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
# Optional: set when calling an API protected by Auth0
VITE_AUTH0_AUDIENCE=https://api.iproject.app
# Backend API base URL (k8s ingress, e.g. https://api.iproject.app)
VITE_API_BASE_URL=
